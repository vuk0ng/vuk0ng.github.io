<section class="section" id="contact">
  <div class="wrap">
    <div class="contact-layout">
      <div>
        <div class="reveal">
          <div class="eyebrow">Contact</div>
          <h2>Parlons de votre projet</h2>
          <p style="margin-top:12px">Notre équipe revient vers vous sous 24h ouvrées pour planifier un premier échange technique.</p>
        </div>
