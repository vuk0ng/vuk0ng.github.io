<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Netgen Systems — Architecture Réseau & Cybersécurité</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#060c18;--bg2:#09111f;--bg3:#0d1728;--surface:#111e35;--line:rgba(255,255,255,0.07);--accent:#2d7ff9;--accent-h:#1a6adf;--teal:#0fbfbf;--green:#10b981;--text:#e8edf5;--muted:#7a8fa8;--dim:#3d5068;--r:10px}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:'Manrope',system-ui,sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;line-height:1.7;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}ul{list-style:none}img{display:block;max-width:100%}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--accent);border-radius:2px}
.wrap{width:100%;max-width:1320px;margin:0 auto;padding:0 48px}
@media(max-width:768px){.wrap{padding:0 20px}}
.section{padding:100px 0}.section-sm{padding:72px 0}
.eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:.72rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:16px}
.eyebrow::before{content:'';width:20px;height:2px;background:var(--accent);border-radius:2px}
h1{font-family:'Playfair Display',Georgia,serif;font-size:clamp(2.4rem,4.5vw,3.8rem);font-weight:700;line-height:1.1;letter-spacing:-.01em;color:#fff}
h2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(1.7rem,2.8vw,2.4rem);font-weight:700;line-height:1.2;color:#fff}
h3{font-size:1rem;font-weight:700;letter-spacing:.01em;color:#fff}
p{color:var(--muted);font-size:.95rem;line-height:1.75}
.accent-word{color:var(--accent)}
.btn{display:inline-flex;align-items:center;gap:8px;font-size:.875rem;font-weight:600;letter-spacing:.02em;padding:12px 24px;border-radius:var(--r);border:none;cursor:pointer;transition:all .2s ease;white-space:nowrap}
.btn-primary{background:var(--accent);color:#fff}
.btn-primary:hover{background:var(--accent-h);transform:translateY(-1px);box-shadow:0 8px 24px rgba(45,127,249,.3)}
.btn-ghost{background:transparent;border:1px solid var(--line);color:var(--text)}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent)}
/* NAV */
nav{position:fixed;top:0;left:0;width:100%;z-index:200;background:rgba(6,12,24,.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--line);transition:background .3s}
.nav-inner{max-width:1320px;margin:0 auto;padding:0 48px;height:68px;display:flex;align-items:center;justify-content:space-between;gap:32px}
.logo{display:flex;align-items:center;gap:10px;flex-shrink:0}
.logo-mark{width:32px;height:32px;background:var(--accent);border-radius:7px;display:grid;place-items:center}
.logo-mark svg{width:18px;height:18px;fill:none;stroke:#fff;stroke-width:2;stroke-linecap:round}
.logo-text{font-size:.95rem;font-weight:800;letter-spacing:.03em;color:#fff}
.logo-text span{color:var(--accent)}
.nav-links{display:flex;align-items:center;gap:28px}
.nav-links a{font-size:.84rem;font-weight:500;color:var(--muted);transition:color .2s}
.nav-links a:hover{color:#fff}
@media(max-width:900px){.nav-links{display:none}}
@media(max-width:768px){.nav-inner{padding:0 20px}}
/* HERO */
#hero{min-height:100vh;display:flex;align-items:center;padding-top:68px;position:relative;overflow:hidden}
.hero-grid{position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);background-size:64px 64px;mask-image:radial-gradient(ellipse 70% 80% at 60% 40%,black 30%,transparent 80%)}
.hero-glow{position:absolute;top:-200px;right:-200px;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(45,127,249,.12) 0%,transparent 65%);pointer-events:none}
.hero-inner{position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;width:100%;max-width:1320px;margin:0 auto;padding:60px 48px}
@media(max-width:960px){.hero-inner{grid-template-columns:1fr;gap:48px;padding:48px 20px}.hero-visual{display:none}}
.hero-left p{font-size:1rem;max-width:480px;margin:16px 0 32px}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap}
.hero-stats{display:grid;grid-template-columns:repeat(4,1fr);margin-top:48px;border:1px solid var(--line);border-radius:var(--r);overflow:hidden}
.stat{padding:18px 14px;border-right:1px solid var(--line);text-align:center}.stat:last-child{border-right:none}
.stat-n{font-size:1.5rem;font-weight:800;color:#fff;line-height:1;margin-bottom:4px}
.stat-l{font-size:.7rem;color:var(--muted);font-weight:500}
/* RINGS */
.hero-visual{display:flex;align-items:center;justify-content:center}
.rings{position:relative;width:340px;height:340px}
.ring{position:absolute;border-radius:50%;border:1px solid rgba(45,127,249,.18)}
.ring-1{inset:0;animation:spin 18s linear infinite}
.ring-2{inset:30px;border-color:rgba(15,191,191,.15);animation:spin 24s linear infinite reverse}
.ring-3{inset:70px;animation:spin 32s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.ring::after{content:'';position:absolute;width:8px;height:8px;border-radius:50%;background:var(--accent);top:-4px;left:50%;transform:translateX(-50%)}
.ring-2::after{background:var(--teal)}.ring-3::after{background:var(--green)}
.ring-core{position:absolute;inset:100px;border-radius:50%;background:var(--bg3);border:1px solid var(--line);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px}
.ring-core-label{font-size:.62rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.ring-core-val{font-size:1.3rem;font-weight:800;color:var(--accent)}
/* MARQUEE */
.marquee-bar{border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:var(--bg2);padding:14px 0;overflow:hidden}
.marquee-track{display:flex;gap:48px;width:max-content;animation:marquee 30s linear infinite}
.marquee-track:hover{animation-play-state:paused}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.m-item{display:flex;align-items:center;gap:10px;white-space:nowrap;font-size:.77rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--dim)}
.m-dot{width:4px;height:4px;border-radius:50%;background:var(--accent);opacity:.6}
/* SERVICES */
.services-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;margin-top:56px}
@media(max-width:900px){.services-grid{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.services-grid{grid-template-columns:1fr}}
.svc-card{background:var(--bg3);padding:36px 28px;transition:.25s}
.svc-card:hover{background:var(--surface)}
.svc-icon{width:44px;height:44px;border-radius:8px;background:rgba(45,127,249,.1);border:1px solid rgba(45,127,249,.2);display:grid;place-items:center;margin-bottom:20px}
.svc-icon svg{width:20px;height:20px;stroke:var(--accent);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.svc-card h3{margin-bottom:8px;font-size:.95rem}
.svc-card p{font-size:.86rem;color:var(--muted);line-height:1.65}
/* SOLUTIONS */
.sol-layout{display:grid;grid-template-columns:240px 1fr;gap:24px;margin-top:56px}
@media(max-width:860px){.sol-layout{grid-template-columns:1fr}}
.sol-nav{display:flex;flex-direction:column;gap:2px}
@media(max-width:860px){.sol-nav{flex-direction:row;flex-wrap:wrap}}
.sol-btn{display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:8px;font-size:.875rem;font-weight:500;color:var(--muted);cursor:pointer;transition:.15s;border:1px solid transparent;background:none;text-align:left;width:100%;font-family:'Manrope',sans-serif}
@media(max-width:860px){.sol-btn{width:auto}}
.sol-btn:hover{color:var(--text);background:var(--bg3)}
.sol-btn.active{color:#fff;background:var(--bg3);border-color:var(--line)}
.sol-btn.active .sol-btn-dot{background:var(--accent)}
.sol-btn-dot{width:6px;height:6px;border-radius:50%;background:var(--dim);flex-shrink:0;transition:.15s}
.sol-panel{display:none}.sol-panel.active{display:block}
.sol-panel-head{margin-bottom:28px}
.sol-panel-head h3{font-size:1.25rem;font-weight:700;color:#fff;margin-bottom:8px;font-family:'Playfair Display',serif}
.sol-panel-head p{font-size:.9rem}
.sol-features-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:560px){.sol-features-grid{grid-template-columns:1fr}}
.sf{padding:18px 20px;background:var(--bg3);border:1px solid var(--line);border-radius:8px}
.sf strong{display:block;font-size:.88rem;font-weight:600;color:#fff;margin-bottom:4px}
.sf span{font-size:.82rem;color:var(--muted)}
/* PROCESS */
.process-row{display:grid;grid-template-columns:repeat(4,1fr);margin-top:56px;border:1px solid var(--line);border-radius:var(--r);overflow:hidden}
@media(max-width:900px){.process-row{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.process-row{grid-template-columns:1fr}}
.proc{padding:40px 28px;border-right:1px solid var(--line);transition:.2s}
.proc:last-child{border-right:none}
@media(max-width:900px){.proc:nth-child(2){border-right:none}.proc:nth-child(1),.proc:nth-child(2){border-bottom:1px solid var(--line)}}
.proc:hover{background:var(--bg3)}
.proc-n{font-size:2.5rem;font-weight:800;color:rgba(45,127,249,.12);line-height:1;margin-bottom:20px}
.proc h3{font-size:.95rem;margin-bottom:10px}
.proc p{font-size:.84rem;color:var(--muted);line-height:1.65}
/* ARCH */
.arch-section{background:var(--bg2)}
.diagram-box{margin-top:48px;border:1px solid var(--line);border-radius:16px;background:var(--bg3);padding:40px 24px;overflow:hidden}
.n{fill:var(--surface);stroke:rgba(45,127,249,.5);stroke-width:1.5}
.n-core{fill:rgba(45,127,249,.15);stroke:var(--accent);stroke-width:1.8}
.n-fw{fill:rgba(15,191,191,.08);stroke:var(--teal);stroke-width:1.5}
.lnk{stroke:rgba(45,127,249,.35);stroke-width:1.5;stroke-dasharray:5 4;fill:none}
.lnk-hot{stroke:var(--accent);stroke-width:1.8;stroke-dasharray:5 4;fill:none;animation:flow 2s linear infinite}
.lnk-ha{stroke:#ef4444;stroke-width:1.5;stroke-dasharray:4 3;fill:none}
@keyframes flow{to{stroke-dashoffset:-18}}
.lbl{font-family:'Manrope',sans-serif;font-size:11px;fill:var(--muted);text-anchor:middle;dominant-baseline:middle}
.lbl-b{font-family:'Manrope',sans-serif;font-size:11.5px;font-weight:700;fill:var(--text);text-anchor:middle;dominant-baseline:middle}
.lbl-sm{font-family:'Manrope',sans-serif;font-size:10px;fill:var(--dim);text-anchor:middle;dominant-baseline:middle}
/* ZT */
.zt-layout{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
@media(max-width:860px){.zt-layout{grid-template-columns:1fr;gap:40px}}
.zt-pillars{display:flex;flex-direction:column;gap:10px;margin-top:28px}
.zt-pill{display:flex;align-items:center;gap:14px;padding:13px 16px;background:var(--bg3);border:1px solid var(--line);border-left:3px solid var(--accent);border-radius:8px;font-size:.88rem;font-weight:500;color:var(--text)}
.zt-pill-icon{width:28px;height:28px;border-radius:6px;background:rgba(45,127,249,.12);display:grid;place-items:center;flex-shrink:0}
.zt-pill-icon svg{width:14px;height:14px;stroke:var(--accent);fill:none;stroke-width:2;stroke-linecap:round}
/* AUDIT */
.audit-layout{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:56px}
@media(max-width:860px){.audit-layout{grid-template-columns:1fr}}
.a-card{background:var(--bg3);border:1px solid var(--line);border-radius:var(--r);padding:36px}
.a-card.featured{border-color:rgba(45,127,249,.3);background:linear-gradient(150deg,rgba(45,127,249,.06) 0%,var(--bg3) 60%)}
.a-card h3{font-size:.95rem;margin-bottom:20px;color:#fff}
.checklist{display:flex;flex-direction:column;gap:10px}
.chk{display:flex;align-items:flex-start;gap:10px;font-size:.875rem;color:var(--muted)}
.chk-mark{width:18px;height:18px;border-radius:50%;background:rgba(16,185,129,.15);flex-shrink:0;display:grid;place-items:center;margin-top:2px}
.chk-mark svg{width:9px;height:9px;stroke:var(--green);fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
.budget-tiers{display:flex;flex-direction:column;gap:12px;margin-top:20px}
.tier{padding:20px 22px;background:var(--surface);border:1px solid var(--line);border-left:3px solid var(--accent);border-radius:8px}
.tier:nth-child(2){border-left-color:var(--teal)}.tier:nth-child(3){border-left-color:var(--green)}
.tier-label{font-size:.78rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px}
.tier-price{font-size:1.3rem;font-weight:800;color:#fff;line-height:1.2;margin-bottom:4px}
.tier-desc{font-size:.78rem;color:var(--muted)}
.free-card{background:rgba(16,185,129,.05);border:1px solid rgba(16,185,129,.2);border-radius:var(--r);padding:24px 28px;margin-top:20px;display:flex;align-items:center;justify-content:space-between;gap:24px}
@media(max-width:560px){.free-card{flex-direction:column;align-items:flex-start}}
.free-label{font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--green);margin-bottom:4px}
.free-title{font-size:1.3rem;font-weight:800;color:#fff}
.free-sub{font-size:.8rem;color:var(--muted);margin-top:4px}
/* KPI */
.kpi-band{background:var(--bg2);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
.kpi-inner{display:grid;grid-template-columns:repeat(4,1fr);border-left:1px solid var(--line)}
@media(max-width:700px){.kpi-inner{grid-template-columns:1fr 1fr}}
.kpi{padding:44px 24px;border-right:1px solid var(--line);text-align:center}
.kpi-n{font-size:2.1rem;font-weight:800;color:#fff;line-height:1;margin-bottom:8px}
.kpi-n span{color:var(--accent)}
.kpi-l{font-size:.8rem;color:var(--muted);font-weight:500}
/* SECTORS */
.sectors-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:56px}
@media(max-width:860px){.sectors-grid{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.sectors-grid{grid-template-columns:1fr}}
.sec-card{background:var(--bg3);border:1px solid var(--line);border-radius:var(--r);padding:28px 24px;transition:.2s}
.sec-card:hover{border-color:rgba(45,127,249,.3);transform:translateY(-2px)}
.sec-icon{width:36px;height:36px;border-radius:8px;background:rgba(45,127,249,.1);display:grid;place-items:center;margin-bottom:16px}
.sec-icon svg{width:18px;height:18px;stroke:var(--accent);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.sec-card h3{font-size:.92rem;margin-bottom:8px}
.sec-card p{font-size:.82rem;color:var(--muted);line-height:1.6}
/* TESTIMONIALS */
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:56px}
@media(max-width:860px){.testi-grid{grid-template-columns:1fr}}
.testi{background:var(--bg3);border:1px solid var(--line);border-radius:var(--r);padding:32px}
.testi-q{font-size:.9rem;color:var(--text);line-height:1.7;font-weight:400;font-style:italic;margin-bottom:24px;position:relative;padding-top:24px}
.testi-q::before{content:'"';position:absolute;top:-4px;left:0;font-size:2.4rem;font-family:'Playfair Display',serif;color:var(--accent);line-height:1;opacity:.6}
.testi-auth{display:flex;align-items:center;gap:12px}
.testi-av{width:38px;height:38px;border-radius:50%;background:var(--accent);display:grid;place-items:center;font-size:.8rem;font-weight:800;color:#fff;flex-shrink:0}
.testi-name{font-size:.88rem;font-weight:600;color:#fff}
.testi-role{font-size:.77rem;color:var(--muted)}
/* CTA */
.cta-banner{background:var(--bg2);border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:100px 0;text-align:center;position:relative;overflow:hidden}
.cta-banner::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 100% at 50% 50%,rgba(45,127,249,.08),transparent)}
.cta-banner .wrap{position:relative;z-index:1}
.cta-banner h2{margin-bottom:14px}
.cta-banner p{max-width:480px;margin:0 auto 36px}
.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
/* CONTACT */
.contact-layout{display:grid;grid-template-columns:1fr 1.4fr;gap:64px;align-items:start}
@media(max-width:860px){.contact-layout{grid-template-columns:1fr;gap:40px}}
.contact-info{display:flex;flex-direction:column;gap:24px;margin-top:32px}
.ci{display:flex;gap:14px;align-items:flex-start}
.ci-icon{width:40px;height:40px;border-radius:8px;background:rgba(45,127,249,.1);border:1px solid rgba(45,127,249,.2);display:grid;place-items:center;flex-shrink:0}
.ci-icon svg{width:16px;height:16px;stroke:var(--accent);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.ci-title{font-size:.82rem;font-weight:700;color:#fff;margin-bottom:3px}
.ci-val{font-size:.85rem;color:var(--muted)}
.form-box{background:var(--bg3);border:1px solid var(--line);border-radius:var(--r);padding:40px}
@media(max-width:560px){.form-box{padding:24px}}
.form-box h3{font-size:1.05rem;margin-bottom:6px}
.form-box>p{font-size:.82rem;margin-bottom:28px}
.f-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media(max-width:560px){.f-row{grid-template-columns:1fr}}
.f-group{margin-bottom:16px}
label{display:block;font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--dim);margin-bottom:7px}
input,select,textarea{width:100%;padding:11px 14px;background:var(--surface);border:1px solid var(--line);border-radius:7px;color:var(--text);font-family:'Manrope',sans-serif;font-size:.88rem;transition:border-color .2s;outline:none}
input::placeholder,textarea::placeholder{color:var(--dim)}
input:focus,select:focus,textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(45,127,249,.1)}
select{cursor:pointer;appearance:none}select option{background:var(--surface)}
textarea{resize:vertical;min-height:100px}
.form-submit{width:100%;justify-content:center;padding:14px;font-size:.9rem}
.form-note{font-size:.74rem;color:var(--dim);text-align:center;margin-top:12px}
/* FOOTER */
footer{background:var(--bg);border-top:1px solid var(--line);padding:72px 0 36px}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;padding-bottom:48px;border-bottom:1px solid var(--line);margin-bottom:32px}
@media(max-width:900px){.footer-top{grid-template-columns:1fr 1fr;gap:32px}}
@media(max-width:560px){.footer-top{grid-template-columns:1fr}}
.f-brand p{font-size:.85rem;color:var(--muted);margin-top:14px;max-width:240px;line-height:1.6}
.f-col h4{font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text);margin-bottom:16px}
.f-links{display:flex;flex-direction:column;gap:9px}
.f-links a{font-size:.85rem;color:var(--muted);transition:color .2s}
.f-links a:hover{color:var(--accent)}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap}
.footer-copy{font-size:.78rem;color:var(--dim)}
.footer-badges{display:flex;gap:8px;flex-wrap:wrap}
.badge{font-size:.68rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;padding:4px 10px;border:1px solid var(--line);border-radius:4px;color:var(--dim)}
.reveal{opacity:0;transform:translateY(22px);transition:.65s ease}
.reveal.on{opacity:1;transform:none}
</style>
</head>
<body>

<nav id="nav">
  <div class="nav-inner">
    <div class="logo">
      <div class="logo-mark"><svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
      <span class="logo-text">Netgen <span>Systems</span></span>
    </div>
    <ul class="nav-links">
      <li><a href="#services">Services</a></li>
      <li><a href="#solutions">Solutions</a></li>
      <li><a href="#architecture">Architecture</a></li>
      <li><a href="#audit">Budget</a></li>
      <li><a href="#secteurs">Secteurs</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
