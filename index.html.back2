        <text x="480" y="122" text-anchor="middle" class="net-label" fill="var(--danger)">HA sync</text>

        <!-- Core switches -->
        <rect x="200" y="208" width="160" height="40" rx="6" class="net-node"/>
        <text x="280" y="233" text-anchor="middle" class="net-label-bold">CORE-SW-A</text>
        <rect x="600" y="208" width="160" height="40" rx="6" class="net-node"/>
        <text x="680" y="233" text-anchor="middle" class="net-label-bold">CORE-SW-B</text>

        <!-- Distribution -->
        <rect x="60" y="308" width="130" height="36" rx="6" class="net-node"/>
        <text x="125" y="331" text-anchor="middle" class="net-label">DIST-SW LAN</text>
        <rect x="230" y="308" width="130" height="36" rx="6" class="net-node"/>
        <text x="295" y="331" text-anchor="middle" class="net-label">DIST-SW DMZ</text>
        <rect x="600" y="308" width="130" height="36" rx="6" class="net-node"/>
        <text x="665" y="331" text-anchor="middle" class="net-label">DIST-SW WAN</text>
        <rect x="770" y="308" width="130" height="36" rx="6" class="net-node"/>
        <text x="835" y="331" text-anchor="middle" class="net-label">DIST-SW OOB</text>

