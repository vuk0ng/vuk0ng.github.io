        <rect x="40" y="400" width="100" height="32" rx="5" class="net-node" opacity=".7"/>
        <text x="90" y="421" text-anchor="middle" class="net-label">VLAN Users</text>
        <rect x="160" y="400" width="100" height="32" rx="5" class="net-node" opacity=".7"/>
        <text x="210" y="421" text-anchor="middle" class="net-label">VLAN Serveurs</text>
        <rect x="230" y="400" width="120" height="32" rx="5" class="net-node" opacity=".7"/>
        <text x="290" y="421" text-anchor="middle" class="net-label">Serveurs Web/App</text>
