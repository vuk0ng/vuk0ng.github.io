<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Netgen Systems — Architecture Réseau & Cybersécurité</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
/* ── DESIGN TOKENS ── */
:root{
  --bg:#04070f;
  --bg2:#070d1a;
  --bg3:#0b1225;
  --surface:#0e1830;
  --accent:#00c6ff;
  --accent2:#0075ff;
  --accent3:#00ffa3;
  --danger:#ff3e6c;
  --text:#dce8f5;
  --muted:#6b809a;
  --border:rgba(0,198,255,0.12);
  --border2:rgba(255,255,255,0.06);
  --glow-blue:0 0 80px rgba(0,117,255,0.2);
  --glow-cyan:0 0 40px rgba(0,198,255,0.25);
  --r:12px;
}

/* ── RESET ── */
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  font-family:'DM Sans',sans-serif;
  font-size:16px;
  background:var(--bg);
  color:var(--text);
  overflow-x:hidden;
  line-height:1.65;
}
a{color:inherit;text-decoration:none}
ul{list-style:none}
img{max-width:100%;display:block}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--accent2);border-radius:2px}

/* ── TYPOGRAPHY ── */
h1,h2,h3,h4,.logo-name{font-family:'Syne',sans-serif}
h1{font-size:clamp(2.4rem,6vw,4.8rem);font-weight:800;line-height:1.05;letter-spacing:-0.02em}
h2{font-size:clamp(1.6rem,3.5vw,2.6rem);font-weight:700;letter-spacing:-0.01em}
h3{font-size:1.15rem;font-weight:700}
h4{font-size:.85rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent)}

/* ── UTILS ── */
.container{max-width:1160px;margin:auto;padding:0 6%}
.section{padding:120px 0}
.tag{
  display:inline-block;
  font-family:'Syne',sans-serif;
  font-size:.72rem;
  font-weight:700;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:var(--accent);
  border:1px solid var(--border);
  border-radius:99px;
  padding:5px 14px;
  margin-bottom:22px;
}
.gradient-text{
  background:linear-gradient(90deg,#fff 30%,var(--accent));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}
.gradient-text-green{
  background:linear-gradient(90deg,var(--accent3),var(--accent));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}

/* ── BUTTONS ── */
.btn{
  display:inline-flex;align-items:center;gap:8px;
  font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;letter-spacing:.04em;
  padding:13px 26px;border-radius:var(--r);
  border:none;cursor:pointer;transition:.25s ease;
}
.btn-primary{
  background:linear-gradient(135deg,var(--accent2),var(--accent));
  color:#000;
}
.btn-primary:hover{transform:translateY(-2px);box-shadow:var(--glow-cyan)}
.btn-outline{
  background:transparent;
  border:1px solid var(--border);
  color:var(--text);
}
.btn-outline:hover{border-color:var(--accent);color:var(--accent)}

/* ── NAV ── */
nav{
  position:fixed;top:0;width:100%;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:18px 6%;
  background:rgba(4,7,15,.75);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border2);
  transition:.3s;
}
.logo{display:flex;align-items:center;gap:10px}
.logo-icon{
  width:36px;height:36px;border-radius:9px;
  background:linear-gradient(135deg,var(--accent2),var(--accent));
  display:flex;align-items:center;justify-content:center;
  font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;color:#000;
  flex-shrink:0;
}
.logo-name{font-weight:700;font-size:1rem;letter-spacing:.02em}
.logo-name span{color:var(--accent)}
.nav-links{display:flex;align-items:center;gap:32px}
.nav-links a{font-size:.88rem;color:var(--muted);transition:.2s}
.nav-links a:hover{color:var(--text)}
.nav-cta{margin-left:8px}

/* ── HERO ── */
#hero{
  min-height:100vh;
  display:flex;align-items:center;
  padding-top:100px;
  position:relative;
  overflow:hidden;
}
.hero-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(var(--border2) 1px,transparent 1px),
    linear-gradient(90deg,var(--border2) 1px,transparent 1px);
  background-size:60px 60px;
  mask-image:radial-gradient(ellipse 80% 70% at 50% 40%,black,transparent);
}
.hero-glow{
  position:absolute;top:-10%;left:50%;transform:translateX(-50%);
  width:800px;height:500px;
  background:radial-gradient(ellipse,rgba(0,117,255,.18) 0%,transparent 70%);
  pointer-events:none;
}
.hero-content{position:relative;z-index:1;max-width:780px}
.hero-sub{color:var(--muted);font-size:1.05rem;max-width:560px;margin:18px 0 36px}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap}
.hero-stats{
  display:flex;gap:48px;margin-top:72px;
  padding-top:36px;border-top:1px solid var(--border2);
}
.stat-val{
  font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;
  background:linear-gradient(90deg,var(--text),var(--accent));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.stat-label{font-size:.82rem;color:var(--muted);margin-top:4px}

/* ── SCROLL BADGE ── */
.scroll-badge{
  position:absolute;bottom:40px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:10px;
  color:var(--muted);font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;
}
.scroll-line{
  width:1px;height:52px;
  background:linear-gradient(var(--accent),transparent);
  animation:scrollAnim 1.8s ease-in-out infinite;
}
@keyframes scrollAnim{0%,100%{opacity:.3;transform:scaleY(0.6) translateY(-8px)}50%{opacity:1;transform:scaleY(1) translateY(0)}}

/* ── MARQUEE ── */
.marquee-wrap{
  border-top:1px solid var(--border2);
  border-bottom:1px solid var(--border2);
  background:var(--bg2);
  overflow:hidden;
  padding:16px 0;
}
.marquee-track{
  display:flex;gap:60px;
  animation:marquee 25s linear infinite;
  width:max-content;
}
.marquee-track:hover{animation-play-state:paused}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.marquee-item{
  display:flex;align-items:center;gap:10px;
  font-family:'Syne',sans-serif;font-size:.8rem;font-weight:700;letter-spacing:.1em;
  color:var(--muted);white-space:nowrap;text-transform:uppercase;
}
.marquee-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);flex-shrink:0}

/* ── SECTION HEADER ── */
.section-header{margin-bottom:64px}
.section-header p{color:var(--muted);max-width:520px;margin-top:14px;font-size:1rem}

/* ── CARDS GRID ── */
.cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px}

/* ── FEATURE CARD ── */
.feature-card{
  background:var(--bg3);
  border:1px solid var(--border2);
  border-radius:16px;
  padding:32px;
  transition:.3s ease;
  position:relative;overflow:hidden;
}
.feature-card::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(circle at 0 0,rgba(0,198,255,.06),transparent 60%);
  opacity:0;transition:.3s;
}
.feature-card:hover{border-color:var(--border);transform:translateY(-4px);box-shadow:var(--glow-blue)}
.feature-card:hover::before{opacity:1}
.feature-icon{
  width:46px;height:46px;border-radius:10px;
  background:rgba(0,117,255,.15);border:1px solid rgba(0,117,255,.3);
  display:flex;align-items:center;justify-content:center;
  font-size:1.3rem;margin-bottom:20px;
}
.feature-card h3{margin-bottom:10px;font-size:1.05rem}
.feature-card p{color:var(--muted);font-size:.92rem;line-height:1.6}

/* ── SERVICES HERO SECTION ── */
.services-hero{
  display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;
}
.services-visual{
  position:relative;
  aspect-ratio:1;max-width:460px;
}
.net-svg{width:100%;height:100%}

/* ── PROCESS STEPS ── */
.process-steps{
  display:grid;grid-template-columns:repeat(4,1fr);gap:0;
  border:1px solid var(--border2);border-radius:16px;overflow:hidden;
}
.process-step{
  padding:36px 28px;border-right:1px solid var(--border2);
  position:relative;
  transition:.3s;
}
.process-step:last-child{border-right:none}
.process-step:hover{background:var(--bg3)}
.step-num{
  font-family:'Syne',sans-serif;font-size:3rem;font-weight:800;
  color:rgba(0,198,255,.12);line-height:1;margin-bottom:20px;
}
.process-step h3{font-size:.98rem;margin-bottom:10px}
.process-step p{color:var(--muted);font-size:.86rem;line-height:1.6}
.step-arrow{
  position:absolute;right:-12px;top:50%;transform:translateY(-50%);
  width:24px;height:24px;background:var(--surface);
  border:1px solid var(--border2);border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:.7rem;color:var(--accent);z-index:1;
}
.process-step:last-child .step-arrow{display:none}

/* ── SOLUTIONS TABS ── */
.solutions-container{display:grid;grid-template-columns:260px 1fr;gap:32px;align-items:start}
.solutions-tabs{display:flex;flex-direction:column;gap:4px}
.sol-tab{
  display:flex;align-items:center;gap:12px;
  padding:16px 20px;border-radius:10px;
  border:1px solid transparent;
  cursor:pointer;transition:.2s;
  font-size:.9rem;font-weight:500;color:var(--muted);
}
.sol-tab:hover{background:var(--bg3);color:var(--text)}
.sol-tab.active{
  background:var(--bg3);color:var(--accent);
  border-color:var(--border);
}
.sol-tab-icon{font-size:1.1rem;width:28px;text-align:center}
.sol-panel{display:none}
.sol-panel.active{display:block}
.sol-panel-header{margin-bottom:28px}
.sol-panel-header h3{font-size:1.5rem;font-family:'Syne',sans-serif;font-weight:700;margin-bottom:8px}
.sol-panel-header p{color:var(--muted);font-size:.95rem}
.sol-features{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.sol-feature{
  background:var(--bg3);border:1px solid var(--border2);
  border-radius:10px;padding:18px;
  font-size:.88rem;
}
.sol-feature strong{display:block;margin-bottom:4px;font-size:.9rem}
.sol-feature span{color:var(--muted)}

/* ── AUDIT SECTION ── */
.audit-grid{display:grid;grid-template-columns:1fr 1fr;gap:32px}
.audit-card{
  background:var(--bg3);border:1px solid var(--border2);
  border-radius:16px;padding:36px;
}
.audit-card.highlight{
  border-color:rgba(0,198,255,.3);
  background:linear-gradient(135deg,rgba(0,117,255,.08),var(--bg3));
}
.audit-list{margin-top:20px;display:flex;flex-direction:column;gap:12px}
.audit-item{
  display:flex;align-items:flex-start;gap:12px;
  font-size:.92rem;color:var(--muted);
}
.audit-item::before{
  content:'✓';
  width:20px;height:20px;border-radius:50%;
  background:rgba(0,255,163,.15);
  color:var(--accent3);
  display:flex;align-items:center;justify-content:center;
  font-size:.72rem;font-weight:700;flex-shrink:0;
  margin-top:2px;
}
.price-range{
  margin-top:28px;padding:24px;
  background:rgba(0,117,255,.08);border:1px solid rgba(0,117,255,.2);
  border-radius:10px;
}
.price-val{
  font-family:'Syne',sans-serif;font-size:1.8rem;font-weight:800;
  background:linear-gradient(90deg,var(--accent3),var(--accent));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.price-label{color:var(--muted);font-size:.82rem;margin-top:4px}

/* ── KPI BAR ── */
.kpi-bar{
  display:grid;grid-template-columns:repeat(4,1fr);
  background:var(--bg3);border:1px solid var(--border2);border-radius:16px;
  overflow:hidden;
}
.kpi-item{
  padding:40px 28px;border-right:1px solid var(--border2);
  text-align:center;
}
.kpi-item:last-child{border-right:none}
.kpi-num{
  font-family:'Syne',sans-serif;font-size:2.4rem;font-weight:800;
  background:linear-gradient(90deg,var(--text),var(--accent));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  line-height:1;margin-bottom:10px;
}
.kpi-label{color:var(--muted);font-size:.85rem}

/* ── TESTIMONIALS ── */
.testimonials-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.testi-card{
  background:var(--bg3);border:1px solid var(--border2);
  border-radius:16px;padding:32px;
}
.testi-quote{
  color:var(--text);font-size:.95rem;line-height:1.65;
  font-style:italic;font-weight:300;
  margin-bottom:24px;
}
.testi-quote::before{content:'\201C';color:var(--accent);font-size:2rem;line-height:0;vertical-align:-0.5em;margin-right:4px}
.testi-author{display:flex;align-items:center;gap:14px}
.testi-avatar{
  width:42px;height:42px;border-radius:50%;
  background:linear-gradient(135deg,var(--accent2),var(--accent3));
  display:flex;align-items:center;justify-content:center;
  font-family:'Syne',sans-serif;font-weight:800;font-size:.9rem;color:#000;
}
.testi-name{font-weight:500;font-size:.9rem}
.testi-role{color:var(--muted);font-size:.8rem}

/* ── SECTORS ── */
.sectors-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.sector-card{
  background:var(--bg3);border:1px solid var(--border2);border-radius:12px;
  padding:28px;display:flex;gap:16px;align-items:flex-start;
  transition:.25s;
}
.sector-card:hover{border-color:var(--border);transform:translateY(-3px)}
.sector-icon{font-size:1.6rem;line-height:1;flex-shrink:0}
.sector-card h3{font-size:.98rem;margin-bottom:6px}
.sector-card p{color:var(--muted);font-size:.84rem;line-height:1.55}

/* ── NETWORK DIAGRAM ── */
.network-section{background:var(--bg2);padding:100px 0}
.diagram-wrap{
  margin-top:48px;
  border:1px solid var(--border2);border-radius:20px;
  overflow:hidden;padding:40px;
  background:var(--bg3);
}
.net-node{fill:var(--surface);stroke:rgba(0,198,255,.4);stroke-width:1.5}
.net-node-core{fill:rgba(0,117,255,.2);stroke:var(--accent2);stroke-width:2}
.net-line{stroke:rgba(0,198,255,.25);stroke-width:1.5;stroke-dasharray:6 4}
.net-line-active{stroke:rgba(0,198,255,.7);stroke-width:2;stroke-dasharray:6 4;animation:flow 2.5s linear infinite}
@keyframes flow{to{stroke-dashoffset:-20}}
.net-label{fill:var(--muted);font-family:'DM Sans',sans-serif;font-size:11px}
.net-label-bold{fill:var(--text);font-family:'Syne',sans-serif;font-size:12px;font-weight:700}

/* ── CTA SECTION ── */
.cta-section{
  position:relative;overflow:hidden;
  background:linear-gradient(135deg,var(--bg2),var(--bg3));
  border-top:1px solid var(--border2);
  border-bottom:1px solid var(--border2);
  padding:120px 0;text-align:center;
}
.cta-section::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 80% at 50% 50%,rgba(0,117,255,.12),transparent);
}
.cta-section .container{position:relative;z-index:1}
.cta-section h2{font-size:clamp(2rem,4vw,3.2rem);margin-bottom:16px}
.cta-section p{color:var(--muted);max-width:480px;margin:0 auto 36px;font-size:1rem}
.cta-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}

/* ── CONTACT SECTION ── */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start}
.contact-info{display:flex;flex-direction:column;gap:28px}
.contact-item{display:flex;gap:16px;align-items:flex-start}
.contact-icon{
  width:44px;height:44px;border-radius:10px;
  background:rgba(0,117,255,.12);border:1px solid rgba(0,117,255,.25);
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;flex-shrink:0;
}
.contact-item h4{font-size:.92rem;margin-bottom:4px}
.contact-item p{color:var(--muted);font-size:.88rem}
.contact-form{
  background:var(--bg3);border:1px solid var(--border2);
  border-radius:16px;padding:36px;
}
.form-group{margin-bottom:18px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:18px}
label{display:block;font-size:.8rem;font-weight:500;margin-bottom:8px;color:var(--muted);letter-spacing:.04em;text-transform:uppercase}
input,textarea,select{
  width:100%;padding:12px 16px;
  background:var(--surface);border:1px solid var(--border2);
  border-radius:8px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.92rem;
  transition:.2s;outline:none;
}
input:focus,textarea:focus,select:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(0,198,255,.1)}
select{cursor:pointer}
textarea{resize:vertical;min-height:110px}
select option{background:var(--surface)}

/* ── FOOTER ── */
footer{background:var(--bg);border-top:1px solid var(--border2);padding:80px 0 40px}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:64px;margin-bottom:60px}
.footer-brand p{color:var(--muted);font-size:.9rem;margin-top:16px;max-width:260px;line-height:1.6}
.footer-col h4{font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:20px;color:var(--text)}
.footer-links{display:flex;flex-direction:column;gap:10px}
.footer-links a{color:var(--muted);font-size:.88rem;transition:.2s}
.footer-links a:hover{color:var(--accent)}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;padding-top:32px;border-top:1px solid var(--border2)}
.footer-bottom p{color:var(--muted);font-size:.82rem}
.footer-badges{display:flex;gap:12px}
.badge{
  font-size:.72rem;font-family:'Syne',sans-serif;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
  padding:5px 12px;border-radius:99px;border:1px solid var(--border2);color:var(--muted);
}

/* ── ZERO TRUST SECTION ── */
.zt-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.zt-visual{
  background:var(--bg3);border:1px solid var(--border2);
  border-radius:16px;padding:32px;
}
.zt-principles{display:flex;flex-direction:column;gap:16px;margin-top:24px}
.zt-principle{
  display:flex;align-items:center;gap:14px;
  padding:16px;background:var(--surface);border-radius:8px;
  border-left:2px solid var(--accent2);
  font-size:.9rem;
}
.zt-principle .num{
  font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;color:var(--accent);min-width:28px;
}

/* ── RESPONSIVE ── */
@media(max-width:1024px){
  .solutions-container{grid-template-columns:1fr}
  .solutions-tabs{flex-direction:row;flex-wrap:wrap}
  .sol-tab{padding:10px 16px}
  .zt-grid,.audit-grid,.contact-grid,.services-hero{grid-template-columns:1fr;gap:40px}
  .process-steps{grid-template-columns:1fr 1fr}
  .kpi-bar{grid-template-columns:1fr 1fr}
  .kpi-item:nth-child(2){border-right:none}
  .footer-grid{grid-template-columns:1fr 1fr;gap:40px}
}
@media(max-width:768px){
  .nav-links{display:none}
  .hero-stats{flex-wrap:wrap;gap:28px}
  .testimonials-grid,.sectors-grid{grid-template-columns:1fr}
  .process-steps{grid-template-columns:1fr}
  .step-arrow{display:none}
  .sol-features{grid-template-columns:1fr}
  .form-row{grid-template-columns:1fr}
  .footer-grid{grid-template-columns:1fr}
  .footer-bottom{flex-direction:column;gap:16px;text-align:center}
  .kpi-bar{grid-template-columns:1fr 1fr}
}

/* ── ANIMATIONS ── */
.reveal{opacity:0;transform:translateY(28px);transition:.7s ease}
.reveal.visible{opacity:1;transform:none}
</style>
</head>
<body>

<!-- ─────────────── NAV ─────────────── -->
<nav id="nav">
  <div class="logo">
    <div class="logo-icon">N</div>
    <span class="logo-name">Netgen <span>Systems</span></span>
  </div>
  <ul class="nav-links">
