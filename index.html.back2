<div class="network-section" id="architecture">
  <div class="container">
    <div class="section-header reveal">
      <div class="tag">Architecture réseau</div>
      <h2>Infrastructure multi-couche haute disponibilité</h2>
      <p>Nous concevons des architectures redondantes, segmentées et supervisées — du cœur de réseau jusqu'aux postes de travail.</p>
    </div>
    <div class="diagram-wrap reveal">
      <svg viewBox="0 0 960 480" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto">
        <!-- Internet -->
        <rect x="390" y="20" width="180" height="44" rx="8" class="net-node-core"/>
        <text x="480" y="47" text-anchor="middle" class="net-label-bold">INTERNET</text>

        <!-- FW pair -->
        <rect x="280" y="108" width="150" height="40" rx="6" class="net-node"/>
        <text x="355" y="133" text-anchor="middle" class="net-label-bold">FW-01 (actif)</text>
        <rect x="530" y="108" width="150" height="40" rx="6" class="net-node"/>
        <text x="605" y="133" text-anchor="middle" class="net-label-bold">FW-02 (passif)</text>
