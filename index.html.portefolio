<!-- ============================================================
     JAVASCRIPT
============================================================ -->
<script>
/* ---- CURSOR ---- */
const dot  = document.getElementById('cursorDot');
const ring = document.getElementById('cursorRing');
document.addEventListener('mousemove', e => {
  dot.style.left  = e.clientX + 'px'; dot.style.top  = e.clientY + 'px';
  ring.style.left = e.clientX + 'px'; ring.style.top = e.clientY + 'px';
});
document.querySelectorAll('a,button,.skill-category,.project-card,.tl-content,.stat-box').forEach(el => {
  el.addEventListener('mouseenter', () => ring.classList.add('hovered'));
  el.addEventListener('mouseleave', () => ring.classList.remove('hovered'));
});

/* ---- MATRIX RAIN ---- */
(function(){
  const c = document.getElementById('matrix-bg');
  const ctx = c.getContext('2d');
  function resize(){ c.width = window.innerWidth; c.height = window.innerHeight; }
  resize(); window.addEventListener('resize', resize);
  const chars = '01アイウエオカキクケコサシスセソタチツテトナニヌネノABCDEFGHIJKLMNOPQRSTUVWXYZ';
  const fontSize = 13;
  let drops = [];
  function init(){
    drops = [];
    const cols = Math.floor(c.width / fontSize);
    for(let i = 0; i < cols; i++) drops[i] = Math.random() * -100;
  }
  init(); window.addEventListener('resize', init);
  setInterval(() => {
    ctx.fillStyle = 'rgba(10,13,15,0.04)';
    ctx.fillRect(0, 0, c.width, c.height);
    ctx.fillStyle = '#00d4ff';
    ctx.font = fontSize + 'px JetBrains Mono';
    drops.forEach((y, i) => {
      const ch = chars[Math.floor(Math.random() * chars.length)];
      ctx.fillText(ch, i * fontSize, y * fontSize);
      if(y * fontSize > c.height && Math.random() > 0.975) drops[i] = 0;
      drops[i]++;
    });
  }, 60);
})();

/* ---- TERMINAL TYPEWRITER ---- */
(function(){
  const lines = [
    // ---- Modifie les lignes du terminal ----
    { type: 'prompt', text: 'whoami' },
    { type: 'output', text: 'quentin.farrokhian — Admin Réseaux & Systèmes' },
    { type: 'prompt', text: 'cat profile.txt' },
    { type: 'output', text: '[status]    Alternant @ La Mutuelle Verte', delay: 200 },
    { type: 'output', text: '[diplôme]   BUT R&T Parcours Cyber – Luminy', delay: 400 },
    { type: 'output', text: '[passion]   Réseaux / Cybersécurité / Infra', delay: 600 },
    { type: 'prompt', text: 'nmap -sV --top-skills' },
    { type: 'output', text: '22/tcp   open  ssh         Cisco IOS' },
    { type: 'output', text: '80/tcp   open  http        PHP/SQL/JS' },
    { type: 'output', text: '443/tcp  open  https       TLS 1.3' },
    { type: 'output', text: '3389/tcp open  rdp         Windows Server' },
    { type: 'prompt', text: 'ping -c 1 avenir.pro', last: true },
    { type: 'output', text: 'PONG from master.cyber — time=0.42ms' },
  ];

  const container = document.getElementById('terminal-body');
  let li = 0;

  function addLine(line) {
    const div = document.createElement('div');
    div.className = 't-line';
    if(line.type === 'prompt') {
      div.innerHTML = `<span class="t-prompt">quentin@portfolio:~$ </span><span class="t-cmd"></span>`;
    } else {
      div.innerHTML = `<div class="t-output" style="opacity:0"></div>`;
    }
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;

    if(line.type === 'prompt') {
      const cmdEl = div.querySelector('.t-cmd');
      let ci = 0;
      const iv = setInterval(() => {
        cmdEl.textContent = line.text.slice(0, ci++);
        if(ci > line.text.length) {
          clearInterval(iv);
          setTimeout(() => nextLine(), 400);
        }
      }, 45);
    } else {
      const out = div.querySelector('.t-output');
      out.style.opacity = '1';
      out.textContent = line.text;
      setTimeout(() => nextLine(), 180);
    }
  }

  function nextLine() {
    if(li >= lines.length) {
      const cursor = document.createElement('div');
      cursor.className = 't-line';
      cursor.innerHTML = `<span class="t-prompt">quentin@portfolio:~$ </span><span class="t-cursor-blink"></span>`;
      container.appendChild(cursor);
      return;
    }
    const line = lines[li++];
    setTimeout(() => addLine(line), line.delay || 0);
  }

  setTimeout(() => nextLine(), 800);
})();

/* ---- SCROLL REVEAL ---- */
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.08 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
</body>
</html>
