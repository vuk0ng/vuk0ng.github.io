<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quentin Farrokhian — Réseaux & Cybersécurité</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  /* ============================================================
     CONFIGURATION — Modifie ces variables pour personnaliser
  ============================================================ */
  :root {
    --color-bg:       #0a0d0f;
    --color-surface:  #0f1419;
    --color-border:   #1e2d3d;
    --color-accent:   #00d4ff;        /* Couleur principale */
    --color-accent2:  #00ff88;        /* Couleur secondaire */
    --color-accent3:  #ff6b35;        /* Couleur tertiaire */
    --color-text:     #c9d1d9;
    --color-muted:    #6e7681;
    --color-white:    #f0f6fc;

    --font-mono: 'JetBrains Mono', monospace;
    --font-display: 'Syne', sans-serif;

    /* ---- Contenu — Modifie ici ---- */
    --name:           "QUENTIN FARROKHIAN";
    --tagline:        "Réseaux & Cybersécurité";
    --location:       "Toulon / Marseille / Annecy";
  }

  /* ============================================================
     RESET & BASE
  ============================================================ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.7;
    overflow-x: hidden;
    cursor: none;
  }

  /* ============================================================
     CUSTOM CURSOR
  ============================================================ */
  .cursor {
    position: fixed; top: 0; left: 0; z-index: 9999;
    pointer-events: none;
  }
  .cursor-dot {
    width: 8px; height: 8px;
    background: var(--color-accent);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.1s ease;
  }
  .cursor-ring {
    position: fixed; top: 0; left: 0;
    width: 32px; height: 32px;
    border: 1px solid var(--color-accent);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.15s ease, width 0.2s, height 0.2s, border-color 0.2s;
    pointer-events: none; z-index: 9998;
    opacity: 0.6;
  }
  .cursor-ring.hovered {
    width: 48px; height: 48px;
    border-color: var(--color-accent2);
    opacity: 1;
  }

  /* ============================================================
     SCAN LINE OVERLAY
  ============================================================ */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 9990;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
    pointer-events: none;
  }

  /* ============================================================
     MATRIX RAIN (canvas)
  ============================================================ */
  #matrix-bg {
    position: fixed; inset: 0; z-index: 0;
    opacity: 0.06;
    pointer-events: none;
  }

  /* ============================================================
     NAV
  ============================================================ */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 2.5rem;
    background: rgba(10,13,15,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1rem; font-weight: 800;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    text-decoration: none;
  }
  .nav-logo span { color: var(--color-accent2); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.2s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute; bottom: -4px; left: 0; right: 100%;
    height: 1px; background: var(--color-accent);
    transition: right 0.25s ease;
  }
  .nav-links a:hover { color: var(--color-accent); }
  .nav-links a:hover::after { right: 0; }
  .nav-status {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.7rem; color: var(--color-muted);
  }
  .status-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--color-accent2);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  /* ============================================================
     HERO
  ============================================================ */
  .hero {
    position: relative; z-index: 1;
    min-height: 100vh;
    display: flex; align-items: center;
    padding: 6rem 2.5rem 3rem;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: center;
    max-width: 1200px; margin: 0 auto; width: 100%;
  }
  .hero-terminal {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 0 60px rgba(0,212,255,0.08), 0 0 0 1px rgba(0,212,255,0.05);
  }
  .terminal-header {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: #161b22;
    border-bottom: 1px solid var(--color-border);
  }
  .terminal-btn {
    width: 12px; height: 12px; border-radius: 50%;
  }
  .t-red   { background: #ff5f57; }
  .t-yellow{ background: #febc2e; }
  .t-green { background: #28c840; }
  .terminal-title {
    margin-left: 0.5rem;
    font-size: 0.7rem; color: var(--color-muted);
    flex: 1; text-align: center;
  }
  .terminal-body {
    padding: 1.5rem;
    min-height: 340px;
    font-size: 0.82rem;
  }
  .t-line { margin-bottom: 0.3rem; }
  .t-prompt { color: var(--color-accent2); }
  .t-cmd    { color: var(--color-white); }
  .t-output { color: var(--color-text); padding-left: 1.2rem; }
  .t-highlight { color: var(--color-accent); }
  .t-warn { color: var(--color-accent3); }
  .t-cursor-blink {
    display: inline-block;
    width: 8px; height: 1.1em;
    background: var(--color-accent);
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  .hero-info { }
  .hero-label {
    font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--color-accent); margin-bottom: 0.75rem;
  }
  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.05;
    color: var(--color-white);
    margin-bottom: 0.5rem;
  }
  .hero-name span { color: var(--color-accent); }
  .hero-subtitle {
    font-family: var(--font-display);
    font-size: 1.1rem; font-weight: 400;
    color: var(--color-accent2);
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }
  .hero-desc {
    color: var(--color-muted);
    font-size: 0.85rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    max-width: 440px;
    /* ---- Modifie cette description ---- */
  }
  .hero-badges {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .badge {
    font-size: 0.7rem; letter-spacing: 0.05em;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    color: var(--color-muted);
    transition: all 0.2s;
  }
  .badge:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(0,212,255,0.05);
  }
  .badge.primary {
    border-color: var(--color-accent2);
    color: var(--color-accent2);
  }
  .hero-cta {
    display: flex; gap: 1rem; flex-wrap: wrap;
  }
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
  }
  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
    font-weight: 700;
  }
  .btn-primary:hover {
    background: #fff; color: var(--color-bg);
    box-shadow: 0 0 20px rgba(0,212,255,0.4);
  }
  .btn-outline {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }
  .btn-outline:hover {
    border-color: var(--color-accent2);
    color: var(--color-accent2);
  }

  /* ============================================================
     SECTION GENERIC
  ============================================================ */
  section { position: relative; z-index: 1; }
  .container { max-width: 1200px; margin: 0 auto; padding: 5rem 2.5rem; }
  .section-header {
    display: flex; align-items: center; gap: 1rem;
    margin-bottom: 3.5rem;
  }
  .section-num {
    font-size: 0.65rem; color: var(--color-accent);
    letter-spacing: 0.15em;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.8rem; font-weight: 800;
    color: var(--color-white);
    letter-spacing: -0.02em;
  }
  .section-line {
    flex: 1; height: 1px;
    background: linear-gradient(90deg, var(--color-border), transparent);
  }

  /* ============================================================
     ABOUT
  ============================================================ */
  #about { background: var(--color-surface); border-top: 1px solid var(--color-border); }
  .about-grid {
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 4rem; align-items: start;
  }
  .about-text p {
    color: var(--color-text);
    font-size: 0.88rem;
    line-height: 1.9;
    margin-bottom: 1rem;
  }
  .about-text p strong { color: var(--color-accent); font-weight: 500; }
  .about-stats {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  }
  .stat-box {
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-align: center;
    transition: all 0.25s;
    position: relative; overflow: hidden;
  }
  .stat-box::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 100%; height: 2px;
    background: var(--color-accent);
    transition: right 0.3s ease;
  }
  .stat-box:hover::before { right: 0; }
  .stat-box:hover { border-color: var(--color-accent); background: rgba(0,212,255,0.03); }
  .stat-num {
    font-family: var(--font-display);
    font-size: 2rem; font-weight: 800;
    color: var(--color-accent);
    display: block;
  }
  .stat-label {
    font-size: 0.7rem; color: var(--color-muted);
    letter-spacing: 0.1em; text-transform: uppercase;
  }
  .info-list { margin-top: 1.5rem; }
  .info-item {
    display: flex; gap: 0.75rem; align-items: flex-start;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(30,45,61,0.5);
    font-size: 0.82rem;
  }
  .info-key { color: var(--color-accent2); min-width: 80px; }
  .info-val { color: var(--color-text); }

  /* ============================================================
     EXPERIENCE
  ============================================================ */
  .timeline { position: relative; }
  .timeline::before {
    content: '';
    position: absolute; left: 140px; top: 0; bottom: 0;
    width: 1px; background: var(--color-border);
  }
  .tl-item {
    display: grid; grid-template-columns: 140px 1fr;
    gap: 2rem; margin-bottom: 3rem;
    position: relative;
  }
  .tl-item::before {
    content: '';
    position: absolute; left: 133px; top: 8px;
    width: 14px; height: 14px;
    border: 1px solid var(--color-accent);
    background: var(--color-bg);
    border-radius: 50%;
    transition: background 0.2s, box-shadow 0.2s;
  }
  .tl-item:hover::before {
    background: var(--color-accent);
    box-shadow: 0 0 16px var(--color-accent);
  }
  .tl-date {
    text-align: right;
    padding-top: 4px;
    font-size: 0.7rem; color: var(--color-muted);
    line-height: 1.5;
  }
  .tl-date .year { color: var(--color-accent); font-size: 0.8rem; }
  .tl-content {
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-surface);
    transition: border-color 0.25s, transform 0.25s;
  }
  .tl-content:hover {
    border-color: rgba(0,212,255,0.3);
    transform: translateX(4px);
  }
  .tl-company {
    font-size: 0.7rem; color: var(--color-accent2);
    letter-spacing: 0.1em; text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .tl-role {
    font-family: var(--font-display);
    font-size: 1rem; font-weight: 700;
    color: var(--color-white); margin-bottom: 0.3rem;
  }
  .tl-type {
    display: inline-block; font-size: 0.65rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--color-accent3);
    color: var(--color-accent3); border-radius: 2px;
    margin-bottom: 0.75rem; letter-spacing: 0.05em;
  }
  .tl-list { list-style: none; }
  .tl-list li {
    font-size: 0.8rem; color: var(--color-muted);
    padding: 0.2rem 0; padding-left: 1rem; position: relative;
  }
  .tl-list li::before {
    content: '›'; position: absolute; left: 0;
    color: var(--color-accent);
  }
  .tl-tags {
    display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.75rem;
  }
  .tl-tag {
    font-size: 0.65rem; padding: 0.2rem 0.5rem;
    background: rgba(0,212,255,0.06);
    border: 1px solid rgba(0,212,255,0.15);
    color: var(--color-accent); border-radius: 2px;
  }

  /* ============================================================
     SKILLS
  ============================================================ */
  #skills { background: var(--color-surface); border-top: 1px solid var(--color-border); }
  .skills-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .skill-category {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    transition: all 0.25s;
    position: relative; overflow: hidden;
  }
  .skill-category::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
    background: var(--color-accent);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s ease;
  }
  .skill-category:hover { border-color: rgba(0,212,255,0.3); background: rgba(0,212,255,0.02); }
  .skill-category:hover::after { transform: scaleX(1); }
  .skill-cat-icon {
    font-size: 1.5rem; margin-bottom: 0.75rem;
    display: block;
  }
  .skill-cat-title {
    font-family: var(--font-display);
    font-size: 0.85rem; font-weight: 700;
    color: var(--color-white); margin-bottom: 1rem;
    letter-spacing: 0.03em;
  }
  .skill-items { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .skill-item {
    font-size: 0.7rem; padding: 0.25rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 2px; color: var(--color-muted);
    transition: all 0.15s;
  }
  .skill-item:hover {
    border-color: var(--color-accent2);
    color: var(--color-accent2);
    background: rgba(0,255,136,0.04);
  }
  /* Langues */
  .lang-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;
    margin-top: 2.5rem;
  }
  .lang-card {
    display: flex; align-items: center; gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border); border-radius: 4px;
  }
  .lang-flag { font-size: 1.5rem; }
  .lang-name { color: var(--color-white); font-size: 0.85rem; margin-bottom: 0.15rem; }
  .lang-level { font-size: 0.7rem; color: var(--color-muted); }
  .lang-level span { color: var(--color-accent2); }

  /* ============================================================
     PROJETS
  ============================================================ */
  .projects-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .project-card {
    padding: 1.5rem;
    border: 1px solid var(--color-border); border-radius: 4px;
    background: var(--color-surface);
    transition: all 0.25s; position: relative;
    overflow: hidden;
  }
  .project-card::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(0,212,255,0.04), transparent);
    opacity: 0; transition: opacity 0.3s;
  }
  .project-card:hover { border-color: rgba(0,212,255,0.3); transform: translateY(-4px); }
  .project-card:hover::before { opacity: 1; }
  .project-num {
    font-size: 0.65rem; color: var(--color-muted);
    letter-spacing: 0.1em; margin-bottom: 1rem;
  }
  .project-title {
    font-family: var(--font-display);
    font-size: 0.95rem; font-weight: 700;
    color: var(--color-white); margin-bottom: 0.75rem;
    line-height: 1.4;
  }
  .project-desc {
    font-size: 0.78rem; color: var(--color-muted);
    line-height: 1.7; margin-bottom: 1rem;
  }
  .project-stack { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .proj-tag {
    font-size: 0.65rem; padding: 0.2rem 0.5rem;
    background: rgba(255,107,53,0.08);
    border: 1px solid rgba(255,107,53,0.2);
    color: var(--color-accent3); border-radius: 2px;
  }

  /* ============================================================
     FORMATION
  ============================================================ */
  #education { background: var(--color-surface); border-top: 1px solid var(--color-border); }
  .edu-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .edu-card {
    padding: 1.5rem;
    border: 1px solid var(--color-border); border-radius: 4px;
    position: relative; overflow: hidden;
    transition: all 0.25s;
  }
  .edu-card::before {
    content: '';
    position: absolute; top: 0; left: 0; width: 3px; height: 0;
    background: var(--color-accent);
    transition: height 0.35s ease;
  }
  .edu-card:hover { border-color: rgba(0,212,255,0.3); }
  .edu-card:hover::before { height: 100%; }
  .edu-period {
    font-size: 0.68rem; color: var(--color-accent);
    letter-spacing: 0.1em; margin-bottom: 0.5rem;
  }
  .edu-degree {
    font-family: var(--font-display);
    font-size: 0.9rem; font-weight: 700;
    color: var(--color-white); margin-bottom: 0.25rem; line-height: 1.4;
  }
  .edu-school { font-size: 0.78rem; color: var(--color-accent2); margin-bottom: 0.25rem; }
  .edu-location { font-size: 0.72rem; color: var(--color-muted); }

  /* ============================================================
     CONTACT
  ============================================================ */
  #contact { border-top: 1px solid var(--color-border); }
  .contact-wrapper {
    text-align: center; max-width: 680px; margin: 0 auto;
    padding: 5rem 2.5rem;
  }
  .contact-pre {
    font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--color-accent); margin-bottom: 1rem;
  }
  .contact-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem); font-weight: 800;
    color: var(--color-white); line-height: 1.1;
    margin-bottom: 1.5rem;
  }
  .contact-desc { color: var(--color-muted); font-size: 0.85rem; margin-bottom: 2.5rem; }
  .contact-links {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem;
    margin-bottom: 3rem;
  }
  .contact-link {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--color-border); border-radius: 2px;
    color: var(--color-text); text-decoration: none;
    font-size: 0.8rem; transition: all 0.2s;
  }
  .contact-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(0,212,255,0.05);
  }
  .contact-link .icon { font-size: 1rem; }

  /* ============================================================
     FOOTER
  ============================================================ */
  footer {
    padding: 2rem 2.5rem;
    border-top: 1px solid var(--color-border);
    display: flex; justify-content: space-between; align-items: center;
    font-size: 0.7rem; color: var(--color-muted);
    position: relative; z-index: 1;
  }

  /* ============================================================
     REVEAL ANIMATIONS
  ============================================================ */
  .reveal {
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible { opacity: 1; transform: none; }

  /* ============================================================
     RESPONSIVE
  ============================================================ */
  @media (max-width: 900px) {
    .hero-grid, .about-grid, .skills-grid,
    .projects-grid, .edu-grid { grid-template-columns: 1fr; }
    .timeline::before { left: 0; }
    .tl-item { grid-template-columns: 1fr; padding-left: 1.5rem; }
    .tl-item::before { left: -7px; }
    .tl-date { text-align: left; }
    .lang-grid { grid-template-columns: 1fr 1fr; }
    nav { padding: 1rem; }
    .nav-links { gap: 1rem; }
  }

  /* Glitch effect on hero name */
  @keyframes glitch1 {
    0%,98%,100%{clip-path:none;transform:none}
    99%{clip-path:polygon(0 20%,100% 20%,100% 30%,0 30%);transform:translateX(-4px)}
  }
  @keyframes glitch2 {
    0%,97%,100%{clip-path:none;transform:none}
    98%{clip-path:polygon(0 65%,100% 65%,100% 75%,0 75%);transform:translateX(4px);color:var(--color-accent3)}
  }
  .hero-name {
    animation: glitch1 7s infinite, glitch2 11s infinite;
  }
</style>
</head>
<body>

<!-- ============================================================
     ÉCRAN DE MOT DE PASSE — Modifie le mot de passe dans le JS ci-dessous
============================================================ -->
<div id="lock-screen" style="
  position:fixed;inset:0;z-index:99999;
  background:#0a0d0f;
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;gap:1.5rem;
  font-family:'JetBrains Mono',monospace;
">
  <div style="
    border:1px solid #1e2d3d;border-radius:8px;
    background:#0f1419;padding:2.5rem 2rem;
    width:100%;max-width:380px;
    box-shadow:0 0 60px rgba(0,212,255,0.08);
    text-align:center;
  ">
    <div style="font-size:2rem;margin-bottom:0.5rem;">&#x1F512;</div>
    <div style="font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:800;color:#f0f6fc;margin-bottom:0.25rem;">Acc&egrave;s restreint</div>
    <div style="font-size:0.72rem;color:#6e7681;margin-bottom:1.5rem;letter-spacing:0.05em;">Entrez le mot de passe pour acc&eacute;der au portfolio</div>
    <input id="lock-input" type="password" placeholder="Mot de passe..." autocomplete="off" style="
      width:100%;padding:0.7rem 1rem;
      background:#0a0d0f;border:1px solid #1e2d3d;
      border-radius:4px;color:#f0f6fc;
      font-family:'JetBrains Mono',monospace;font-size:0.85rem;
      outline:none;margin-bottom:0.75rem;box-sizing:border-box;
      transition:border-color 0.2s;
    ">
    <button onclick="checkPassword()" style="
      width:100%;padding:0.7rem;
      background:#00d4ff;color:#0a0d0f;
      border:none;border-radius:4px;
      font-family:'JetBrains Mono',monospace;font-size:0.78rem;
      font-weight:700;letter-spacing:0.08em;text-transform:uppercase;
      cursor:pointer;transition:all 0.2s;
    " onmouseover="this.style.background='#fff'" onmouseout="this.style.background='#00d4ff'">
      &rarr; Acc&eacute;der
    </button>
    <div id="lock-error" style="
      margin-top:0.75rem;font-size:0.72rem;
      color:#ff6b35;opacity:0;transition:opacity 0.3s;
      letter-spacing:0.05em;
    ">&#x26A0; Mot de passe incorrect</div>
  </div>
  <div style="font-size:0.65rem;color:#2a3a4a;letter-spacing:0.1em;">QUENTIN FARROKHIAN &mdash; PORTFOLIO</div>
</div>

<script>
  // ---- Modifie le mot de passe ici ----
  var ACCESS_PASSWORD = "QuentinPF2026!";

  var lockInput = document.getElementById("lock-input");
  lockInput.addEventListener("focus", function(){ lockInput.style.borderColor="#00d4ff"; });
  lockInput.addEventListener("blur",  function(){ lockInput.style.borderColor="#1e2d3d"; });
  lockInput.addEventListener("keydown", function(e){ if(e.key==="Enter") checkPassword(); });

  function checkPassword() {
    if(lockInput.value === ACCESS_PASSWORD) {
      var screen = document.getElementById("lock-screen");
      screen.style.transition = "opacity 0.5s ease";
      screen.style.opacity = "0";
      setTimeout(function(){ screen.remove(); }, 500);
    } else {
      var err = document.getElementById("lock-error");
      err.style.opacity = "1";
      lockInput.style.borderColor = "#ff6b35";
      lockInput.value = "";
      lockInput.focus();
      setTimeout(function(){ err.style.opacity="0"; lockInput.style.borderColor="#1e2d3d"; }, 2500);
    }
  }
</script>


